  "urgency_matrix": {
    "critical": {
      "description": "Immediate action required — within 24–72 hours",
      "scenarios": ["illegal_eviction", "domestic_violence", "upi_fraud", "unauthorized_transaction", "stalking_harassment", "loan_app_harassment", "property_fraud"],
      "first_step": "Call helpline or police immediately, then document"
    },
    "high": {
      "description": "Action required within 7–15 days",
      "scenarios": ["salary_withholding", "wrongful_termination", "cheque_bounce", "insurance_claim_rejection", "builder_rera"],
      "first_step": "Send legal notice within 15 days"
    },
    "medium": {
      "description": "Action within 30–60 days",
      "scenarios": ["deposit_refusal", "defective_product", "pf_esi_not_deposited", "education_fee_refund", "money_lending_recovery"],
      "first_step": "Document everything, send legal notice"
    },
    "low": {
      "description": "No immediate deadline, proceed methodically",
      "scenarios": ["rent_agreement_dispute", "noise_pollution", "neighbour_dispute"],
      "first_step": "Written complaint to relevant authority"
    }
  },

  "limitation_periods": {
    "note": "Limitation Act 1963 — suit must be filed within these periods or loses right",
    "periods": [
      {"scenario": "Cheque bounce (NI Act 138 complaint)", "period": "30 days from notice expiry", "critical": true},
      {"scenario": "Consumer complaint (DCDRC)", "period": "2 years from date of cause of action", "critical": false},
      {"scenario": "Civil money recovery suit", "period": "3 years from due date", "critical": false},
      {"scenario": "Service conditions disputes (Labour)", "period": "3 years", "critical": false},
      {"scenario": "Property suits (based on possession)", "period": "12 years", "critical": false},
      {"scenario": "Cyber crime FIR", "period": "No strict limit but report immediately", "critical": true},
      {"scenario": "POSH complaint to ICC", "period": "3 months from incident (extendable by 3 more)", "critical": true},
      {"scenario": "RERA complaint", "period": "Varies by state; generally no strict bar", "critical": false}
    ]
  },

